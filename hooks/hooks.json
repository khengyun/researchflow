{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/session_start.py",
            "timeout": 20,
            "statusMessage": "Loading ResearchFlow status"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/user_prompt_submit.py",
            "timeout": 20,
            "statusMessage": "Searching ResearchFlow prior work"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/post_tool_use.py",
            "timeout": 25,
            "statusMessage": "Scanning ResearchFlow artifacts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/stop.py",
            "timeout": 35,
            "statusMessage": "Closing ResearchFlow session"
          }
        ]
      }
    ]
  }
}
